{
  "name": "universui",
  "productName": "Universui",
  "version": "0.1.0",
  "description": "Local-first desktop editor combining task management with professional code editing",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "concurrently \"npm run build:main:dev\" \"npm run build:renderer:dev\" \"wait-on dist/main/main.js dist/renderer/index.html && electron .\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "webpack --config webpack.main.config.js --mode production",
    "build:main:dev": "webpack --config webpack.main.config.js --mode development --watch",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build:renderer:dev": "webpack serve --config webpack.renderer.config.js --mode development",
    "electron": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "jest",
    "lint": "eslint src/**/*.ts src/**/*.tsx"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@vscode/codicons": "^0.0.45",
    "better-sqlite3": "^11.0.0",
    "react": "^18.2.0",
    "react-dnd": "^14.0.0",
    "react-dnd-html5-backend": "^14.0.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "styled-components": "^5.3.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/styled-components": "^5.1.36",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.0",
    "eslint": "^8.55.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.7.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  }
}
