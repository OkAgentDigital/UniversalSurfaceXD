{
  "name": "universalsurfacexd",
  "productName": "Surface",
  "version": "1.5.0",
  "description": "Surface — Local-first desktop editor combining task management with professional code editing.",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "npm run build:preload && concurrently --kill-others \"npm run build:main:dev\" \"npm run build:renderer:dev\" \"wait-on http://localhost:3000 && DEV_SERVER_URL=true electron .\"",
    "start:dev": "npm run build:preload && concurrently --kill-others \"npm run build:main:dev\" \"npm run build:renderer:dev\" \"wait-on http://localhost:3000 && DEV_SERVER_URL=true electron .\"",
    "start:prod": "npm run build && electron .",
    "build": "npm run build:preload && npm run build:main && npm run build:renderer",
    "build:main": "webpack --config webpack.main.config.js --mode production",
    "build:main:dev": "webpack --config webpack.main.config.js --mode development --watch",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build:renderer:dev": "webpack serve --config webpack.renderer.config.js --mode development",
    "build:preload": "webpack --config webpack.preload.config.js --mode production",
    "build:preload:dev": "webpack --config webpack.preload.config.js --mode development",
    "electron": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:mac:release": "npm run build && electron-builder --mac --publish always",
    "build:mac:draft": "npm run build && electron-builder --mac --publish onTag",
    "build:linux": "electron-builder --linux",
    "build:linux:release": "npm run build && electron-builder --linux --publish always",
    "build:win:release": "npm run build && electron-builder --win --publish always",
    "release": "npm run build && electron-builder --mac --win --linux --publish always",
    "release:draft": "npm run build && electron-builder --mac --win --linux --publish onTag",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "jest",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "stack": "npx ts-node src/main/stackManager.ts",
    "stack:list": "npx ts-node src/main/stackManager.ts list",
    "stack:install": "npx ts-node src/main/stackManager.ts install",
    "stack:build": "npx ts-node src/main/stackManager.ts build",
    "stack:run": "npx ts-node src/main/stackManager.ts run",
    "stack:remove": "npx ts-node src/main/stackManager.ts remove",
    "stack:validate": "npx ts-node src/main/stackManager.ts validate",
    "stack:create": "npx ts-node src/main/stackManager.ts create",
    "build:stack:full": "bash scripts/build-stack.sh stacks/full.yaml",
    "build:stack:cloud": "bash scripts/build-stack.sh stacks/cloud.yaml",
    "build:stack:embedded": "bash scripts/build-stack.sh stacks/embedded.yaml",
    "build:stack:retro": "bash scripts/build-stack.sh stacks/retro.yaml",
    "build:stack:cli": "bash scripts/build-stack.sh stacks/cli.yaml",
    "build:stack:ci": "bash scripts/build-stack.sh stacks/ci.yaml",
    "build:stack:all": "for f in stacks/*.yaml; do bash scripts/build-stack.sh \"$f\"; done"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/react": "^14.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/styled-components": "^5.1.36",
    "@types/xterm": "^2.0.3",
    "@vscode/codicons": "^0.0.45",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.0",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.55.0",
    "flowbite-react": "^0.12.17",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.7.0",
    "monaco-editor": "^0.55.1",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "react": "^18.2.0",
    "react-dnd": "^14.0.0",
    "react-dnd-html5-backend": "^14.0.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "style-loader": "^3.3.0",
    "styled-components": "^5.3.0",
    "tailwindcss": "^4.3.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.2.4",
    "xterm": "^5.3.0"
  },
  "overrides": {
    "dompurify": "3.4.3",
    "tar": "7.5.15",
    "@tootallnate/once": "3.0.1",
    "cacache": "20.0.4"
  }
}
