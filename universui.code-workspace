{
  "folders": [
    {
      "name": "🛸 Universui",
      "path": "."
    }
  ],
  "settings": {
    // ── Editor ─────────────────────────────────────────────
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.fontFamily": "'JetBrains Mono', 'Cascadia Code', 'SF Mono', monospace",
    "editor.fontSize": 13,
    "editor.lineHeight": 22,
    "editor.minimap.enabled": false,
    "editor.stickyScroll.enabled": true,

    // ── Files ──────────────────────────────────────────────
    "files.exclude": {
      "**/.git": true,
      "**/.DS_Store": true,
      "**/node_modules": true,
      "**/dist": true
    },
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,

    // ── Terminal ───────────────────────────────────────────
    "terminal.integrated.fontFamily": "'JetBrains Mono', monospace",
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.defaultLocation": "editor",

    // ── TypeScript / React ─────────────────────────────────
    "[typescript]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.formatOnSave": true
    },
    "[typescriptreact]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.formatOnSave": true
    },
    "[javascript]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.formatOnSave": true
    },
    "[json]": {
      "editor.insertSpaces": true,
      "editor.tabSize": 2
    },
    "[css]": {
      "editor.insertSpaces": true,
      "editor.tabSize": 2
    },

    // ── Explorer ───────────────────────────────────────────
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.compactFolders": false,
    "explorer.sortOrder": "type",

    // ── Search ─────────────────────────────────────────────
    "search.exclude": {
      "**/node_modules": true,
      "**/dist": true,
      "**/.git": true
    },

    // ── Electron / Webpack ─────────────────────────────────
    "debug.javascript.terminalOptions": {
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  },
  "extensions": {
    "recommendations": [
      // ── Languages ────────────────────────────────────────
      "esbenp.prettier-vscode",
      "dbaeumer.vscode-eslint",
      "bradlc.vscode-tailwindcss",

      // ── React / TypeScript ───────────────────────────────
      "dsznajder.es7-react-js-snippets",
      "ms-vscode.vscode-typescript-next",

      // ── Productivity ─────────────────────────────────────
      "eamodio.gitlens",
      "yzhang.markdown-all-in-one"
    ]
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Universui (Electron Main)",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder}",
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
        "runtimeArgs": ["."],
        "env": {
          "VITE_DEV_SERVER_URL": "true"
        },
        "windows": {
          "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
        }
      }
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Build Universui",
        "type": "npm",
        "script": "build",
        "group": "build",
        "presentation": {
          "reveal": "always",
          "panel": "dedicated"
        }
      },
      {
        "label": "Start Universui (Dev)",
        "type": "npm",
        "script": "start",
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "presentation": {
          "reveal": "always",
          "panel": "dedicated"
        }
      },
      {
        "label": "Build Main Process",
        "type": "npm",
        "script": "build:main",
        "group": "build"
      },
      {
        "label": "Build Renderer",
        "type": "npm",
        "script": "build:renderer",
        "group": "build"
      },
      {
        "label": "Build Preload",
        "type": "npm",
        "script": "build:preload",
        "group": "build"
      }
    ]
  }
}
